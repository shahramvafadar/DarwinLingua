<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Controls.ActionBlockView">
    <Border Padding="18"
            Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
            StrokeShape="RoundRectangle 24"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light=#FFFDF9, Dark=#10161E}">
        <VerticalStackLayout Spacing="14">
            <Label x:Name="CaptionLabel"
                   Style="{DynamicResource Title2}"
                   TextColor="{AppThemeBinding Light=#10212B, Dark=White}" />
            <Button x:Name="ActionButton"
                    CornerRadius="18"
                    Clicked="OnActionButtonClicked" />
        </VerticalStackLayout>
    </Border>
</ContentView>
