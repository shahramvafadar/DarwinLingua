<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Controls.WordListItemView">
    <Border Margin="0,0,0,10"
            Padding="16"
            Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
            StrokeShape="RoundRectangle 18"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#111923}">
        <VerticalStackLayout Spacing="8">
            <Label x:Name="LemmaLabel"
                   Style="{DynamicResource Title2}"
                   TextColor="{AppThemeBinding Light=#10212B, Dark=White}" />
            <Label x:Name="PrimaryMeaningLabel"
                   Style="{DynamicResource Body}" />
            <Border Padding="10,6"
                    HorizontalOptions="Start"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=#EEF4F3, Dark=#202E37}">
                <Label x:Name="MetadataLineLabel"
                       Style="{DynamicResource Caption}" />
            </Border>
        </VerticalStackLayout>
    </Border>
</ContentView>
