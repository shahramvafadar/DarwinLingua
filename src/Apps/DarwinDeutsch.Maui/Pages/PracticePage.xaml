<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.PracticePage">
    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18">
            <Border Padding="24"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=#E8F3F1, Dark=#16212B}">
                <VerticalStackLayout Spacing="10">
                    <Border Padding="10,6"
                            HorizontalOptions="Start"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            BackgroundColor="{AppThemeBinding Light=#FFF8EC, Dark=#22313B}">
                        <Label x:Name="StatusBadgeLabel"
                               Style="{DynamicResource Caption}" />
                    </Border>
                    <Label x:Name="HeadlineLabel"
                           Style="{DynamicResource Headline}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label x:Name="DescriptionLabel"
                           Style="{DynamicResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ProgressSectionLabel"
                   Style="{DynamicResource Title2}" />

            <Border Padding="20"
                    Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="16"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="16">
                    <controls:DetailSectionView x:Name="DueNowSectionView"
                                                Grid.Row="0"
                                                Grid.Column="0" />
                    <controls:DetailSectionView x:Name="SuccessRateSectionView"
                                                Grid.Row="0"
                                                Grid.Column="1" />
                    <controls:DetailSectionView x:Name="MasteredSectionView"
                                                Grid.Row="1"
                                                Grid.Column="0" />
                    <controls:DetailSectionView x:Name="StrugglingSectionView"
                                                Grid.Row="1"
                                                Grid.Column="1" />
                </Grid>
            </Border>

            <Label x:Name="ActionsSectionLabel"
                   Style="{DynamicResource Title2}" />

            <Border Padding="20"
                    Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="12">
                    <controls:ActionBlockView x:Name="StartFlashcardsActionBlockView"
                                              ActionInvoked="OnStartFlashcardsActionInvoked" />
                    <controls:ActionBlockView x:Name="StartQuizActionBlockView"
                                              ActionInvoked="OnStartQuizActionInvoked" />
                    <controls:ActionBlockView x:Name="RefreshPracticeActionBlockView"
                                              ActionInvoked="OnRefreshPracticeActionInvoked" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20"
                    Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="ReviewSessionSectionLabel"
                           Style="{DynamicResource Title2}" />
                    <Label x:Name="ReviewSessionStateLabel"
                           Style="{DynamicResource Body}"
                           IsVisible="False" />
                    <CollectionView x:Name="ReviewSessionCollectionView"
                                    IsVisible="False"
                                    SelectionMode="Single"
                                    SelectionChanged="OnReviewSessionSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <controls:WordListItemView Lemma="{Binding Lemma}"
                                                           PrimaryMeaning="{Binding PrimaryMeaning}"
                                                           MetadataLine="{Binding MetadataLine}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Padding="20"
                    Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="RecentActivitySectionLabel"
                           Style="{DynamicResource Title2}" />
                    <Label x:Name="RecentActivityStateLabel"
                           Style="{DynamicResource Body}"
                           IsVisible="False" />
                    <CollectionView x:Name="RecentActivityCollectionView"
                                    IsVisible="False"
                                    SelectionMode="Single"
                                    SelectionChanged="OnRecentActivitySelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <controls:WordListItemView Lemma="{Binding Lemma}"
                                                           PrimaryMeaning="{Binding PrimaryMeaning}"
                                                           MetadataLine="{Binding MetadataLine}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
