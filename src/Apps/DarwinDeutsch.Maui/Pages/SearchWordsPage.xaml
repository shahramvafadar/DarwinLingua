<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.SearchWordsPage">
    <Grid Padding="24"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="18">
        <Border Grid.Row="0"
                Padding="24"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 4"
                BackgroundColor="{AppThemeBinding Light=#E8F3F1, Dark=#16212B}">
            <VerticalStackLayout Spacing="10">
                <Border Padding="10,6"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="{AppThemeBinding Light=#FFF8EC, Dark=#22313B}">
                    <Label x:Name="StatusBadgeLabel"
                           Style="{DynamicResource Caption}" />
                </Border>
                <Label x:Name="HeadlineLabel"
                       Style="{DynamicResource Headline}"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label x:Name="DescriptionLabel"
                       Style="{DynamicResource Body}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Padding="20"
                Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                StrokeShape="RoundRectangle 4"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
            <VerticalStackLayout Spacing="12">
                <Label x:Name="SearchSectionLabel"
                       Style="{DynamicResource Title2}" />
                <SearchBar x:Name="SearchBarControl"
                           SearchButtonPressed="OnSearchButtonPressed" />
                <Label x:Name="SearchHintLabel"
                       Style="{DynamicResource Body}" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="2"
                Padding="20"
                Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                StrokeShape="RoundRectangle 4"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                  RowSpacing="12">
                <Label x:Name="ResultsSectionLabel"
                       Grid.Row="0"
                       Style="{DynamicResource Title2}" />

                <Label x:Name="EmptyStateLabel"
                       Grid.Row="1"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <Label x:Name="LoadingStateLabel"
                       Grid.Row="2"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <Label x:Name="ErrorStateLabel"
                       Grid.Row="3"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <CollectionView x:Name="WordsCollectionView"
                                Grid.Row="4"
                                SelectionMode="Single"
                                SelectionChanged="OnWordsSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <controls:WordListItemView Lemma="{Binding Lemma}"
                                                       PrimaryMeaning="{Binding PrimaryMeaning}"
                                                       MetadataLine="{Binding MetadataLine}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
