<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.TopicsPage">
    <Grid Padding="24"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="18">
        <Border Grid.Row="0"
                Padding="24"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 4"
                BackgroundColor="{AppThemeBinding Light=#E8F3F1, Dark=#16212B}">
            <VerticalStackLayout Spacing="10">
                <Border Padding="10,6"
                        HorizontalOptions="Start"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="{AppThemeBinding Light=#FFF8EC, Dark=#22313B}">
                    <Label x:Name="StatusBadgeLabel"
                           Style="{DynamicResource Caption}" />
                </Border>
                <Label x:Name="HeadlineLabel"
                       Style="{DynamicResource Headline}"
                       HorizontalOptions="Start"
                       HorizontalTextAlignment="Start"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label x:Name="DescriptionLabel"
                       Style="{DynamicResource Body}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Padding="20"
                Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                StrokeShape="RoundRectangle 4"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
            <VerticalStackLayout Spacing="12">
                <Label x:Name="ShortcutsSectionLabel"
                       Style="{DynamicResource Title2}" />
                <controls:CefrQuickFilterView x:Name="CefrQuickFilterView"
                                              LevelSelected="OnCefrLevelSelected" />

                <controls:ActionBlockView x:Name="SearchActionBlockView"
                                          ActionInvoked="OnSearchActionInvoked" />

                <controls:ActionBlockView x:Name="FavoritesActionBlockView"
                                          ActionInvoked="OnFavoritesActionInvoked" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="2"
                Padding="20"
                Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                StrokeShape="RoundRectangle 4"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                  RowSpacing="12">
                <Label x:Name="TopicsSectionLabel"
                       Grid.Row="0"
                       Style="{DynamicResource Title2}" />

                <Label x:Name="LoadingStateLabel"
                       Grid.Row="1"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <Label x:Name="ErrorStateLabel"
                       Grid.Row="2"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <Label x:Name="EmptyStateLabel"
                       Grid.Row="3"
                       Style="{DynamicResource Body}"
                       IsVisible="False" />

                <CollectionView x:Name="TopicsCollectionView"
                                Grid.Row="4"
                                SelectionMode="Single"
                                SelectionChanged="OnTopicsSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <controls:TopicListItemView DisplayName="{Binding DisplayName}"
                                                        TopicKey="{Binding Key}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
