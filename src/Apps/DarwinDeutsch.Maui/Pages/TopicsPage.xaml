<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Pages.TopicsPage">
    <Grid Padding="24"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
          RowSpacing="12">
        <Label x:Name="HeadlineLabel"
               Grid.Row="0"
               Style="{StaticResource Headline}"
               SemanticProperties.HeadingLevel="Level1" />

        <Label x:Name="DescriptionLabel"
               Grid.Row="1"
               Style="{StaticResource Body}"
               LineBreakMode="WordWrap" />

        <Label x:Name="EmptyStateLabel"
               Grid.Row="2"
               Style="{StaticResource Body}"
               IsVisible="False" />

        <Label x:Name="LoadingStateLabel"
               Grid.Row="3"
               Style="{StaticResource Body}"
               IsVisible="False" />

        <Label x:Name="ErrorStateLabel"
               Grid.Row="4"
               Style="{StaticResource Body}"
               IsVisible="False" />

        <CollectionView x:Name="TopicsCollectionView"
                        Grid.Row="5"
                        SelectionMode="Single"
                        SelectionChanged="OnTopicsSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding DisplayName}"
                                   Style="{StaticResource Title2}" />
                            <Label Text="{Binding Key}"
                                   Style="{StaticResource Body}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
