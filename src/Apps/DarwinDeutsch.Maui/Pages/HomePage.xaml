<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.HomePage">
    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18">
            <Border Padding="24"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{AppThemeBinding Light=#E8F3F1, Dark=#16212B}">
                <Grid ColumnDefinitions="84,*"
                      ColumnSpacing="16">
                    <Border Grid.Column="0"
                            Padding="12"
                            StrokeShape="RoundRectangle 4"
                            BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#1F2B36}">
                        <Grid>
                            <Label x:Name="LogoPlaceholderLabel"
                                   Style="{DynamicResource Caption}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="8"
                                         VerticalOptions="Center">
                        <Label x:Name="AppNameLabel"
                               Style="{DynamicResource SubHeadline}"
                               SemanticProperties.HeadingLevel="Level1" />
                        <Label x:Name="AppSubtitleLabel"
                               Style="{DynamicResource Body}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Label x:Name="ExploreSectionLabel"
                   Style="{DynamicResource Title2}" />

            <Border Padding="20"
                    Stroke="{AppThemeBinding Light=#D8E0E5, Dark=#2B3945}"
                    StrokeShape="RoundRectangle 4"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFCF8, Dark=#111923}">
                <VerticalStackLayout Spacing="16">
                    <controls:CefrQuickFilterView x:Name="CefrQuickFilterView"
                                                  LevelSelected="OnCefrLevelSelected" />

                    <VerticalStackLayout Spacing="12">
                        <controls:ActionBlockView x:Name="PracticeActionBlockView"
                                                  ActionInvoked="OnPracticeActionInvoked" />

                        <controls:ActionBlockView x:Name="SearchActionBlockView"
                                                  ActionInvoked="OnSearchActionInvoked" />

                        <controls:ActionBlockView x:Name="BrowseTopicsActionBlockView"
                                                  ActionInvoked="OnBrowseTopicsActionInvoked" />

                        <controls:ActionBlockView x:Name="FavoritesActionBlockView"
                                                  ActionInvoked="OnFavoritesActionInvoked" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
