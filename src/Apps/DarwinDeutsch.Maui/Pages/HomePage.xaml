<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DarwinDeutsch.Maui.Controls"
             x:Class="DarwinDeutsch.Maui.Pages.HomePage">
    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18">
            <Border Padding="24"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#DFD8F7, Dark=#141414}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="HeadlineLabel"
                           Style="{DynamicResource Headline}"
                           HorizontalOptions="Start"
                           HorizontalTextAlignment="Start"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label x:Name="IntroLabel"
                           Style="{DynamicResource Body}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20">
                <VerticalStackLayout Spacing="16">
                    <controls:DetailSectionView x:Name="CurrentLanguageSectionView" />
                    <controls:DetailSectionView x:Name="MeaningLanguagesSectionView" />
                    <controls:DetailSectionView x:Name="TopicsSectionView" />
                    <controls:DetailSectionView x:Name="SupportedLanguagesSectionView" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20">
                <controls:CefrQuickFilterView x:Name="CefrQuickFilterView"
                                              LevelSelected="OnCefrLevelSelected" />
            </Border>

            <VerticalStackLayout Spacing="12">
                <controls:ActionBlockView x:Name="PracticeActionBlockView"
                                          ActionInvoked="OnPracticeActionInvoked" />

                <controls:ActionBlockView x:Name="SearchActionBlockView"
                                          ActionInvoked="OnSearchActionInvoked" />

                <controls:ActionBlockView x:Name="BrowseTopicsActionBlockView"
                                          ActionInvoked="OnBrowseTopicsActionInvoked" />

                <controls:ActionBlockView x:Name="FavoritesActionBlockView"
                                          ActionInvoked="OnFavoritesActionInvoked" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
