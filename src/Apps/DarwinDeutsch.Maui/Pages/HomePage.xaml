<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DarwinDeutsch.Maui.Pages.HomePage">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label x:Name="HeadlineLabel"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label x:Name="IntroLabel"
                   Style="{StaticResource Body}"
                   LineBreakMode="WordWrap" />

            <VerticalStackLayout Spacing="6">
                <Label x:Name="CurrentLanguageCaptionLabel"
                       Style="{StaticResource Title2}" />
                <Label x:Name="CurrentLanguageValueLabel"
                       Style="{StaticResource Body}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label x:Name="SupportedLanguagesCaptionLabel"
                       Style="{StaticResource Title2}" />
                <Label x:Name="SupportedLanguagesValueLabel"
                       Style="{StaticResource Body}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label x:Name="MeaningLanguagesCaptionLabel"
                       Style="{StaticResource Title2}" />
                <Label x:Name="MeaningLanguagesValueLabel"
                       Style="{StaticResource Body}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label x:Name="TopicsCaptionLabel"
                       Style="{StaticResource Title2}" />
                <Label x:Name="TopicsValueLabel"
                       Style="{StaticResource Body}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label x:Name="CefrBrowseCaptionLabel"
                       Style="{StaticResource Title2}" />
                <FlexLayout Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Start">
                    <Button Text="A1" Clicked="OnCefrBrowseClicked" />
                    <Button Text="A2" Clicked="OnCefrBrowseClicked" />
                    <Button Text="B1" Clicked="OnCefrBrowseClicked" />
                    <Button Text="B2" Clicked="OnCefrBrowseClicked" />
                    <Button Text="C1" Clicked="OnCefrBrowseClicked" />
                    <Button Text="C2" Clicked="OnCefrBrowseClicked" />
                </FlexLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label x:Name="SearchCaptionLabel"
                       Style="{StaticResource Title2}" />
                <Button x:Name="SearchButton"
                        Clicked="OnSearchClicked" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
